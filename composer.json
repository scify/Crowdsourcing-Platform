{
	"name": "laravel/laravel",
	"description": "The Laravel Framework.",
	"keywords": [
		"framework",
		"laravel"
	],
	"license": "MIT",
	"type": "project",
	"require": {
		"php": "^8.3.0",
		"ext-libxml": "*",
		"ext-simplexml": "*",
		"ext-zip": "*",
		"accentinteractive/laravel-logcleaner": "^1.6",
		"awobaz/compoships": "^2.5.4",
		"cocur/slugify": "^4.7.1",
		"doctrine/dbal": "^3.10.4",
		"drewm/mailchimp-api": "^2.5.4",
		"google/cloud-translate": "^1.21",
		"intervention/image": "^2.7.2",
		"laravel/framework": "^12.49",
		"laravel/helpers": "^1.8.2",
		"laravel/socialite": "^5.24.2",
		"laravel/tinker": "^2.11",
		"laravel/ui": "^4.6.1",
		"league/flysystem-aws-s3-v3": "^3.31",
		"nunomaduro/collision": "^8.8.3",
		"phpoffice/phpspreadsheet": "^5.4",
		"predis/predis": "^1.1.10",
		"scify/laravel-cookie-guard": "^4.1.11",
		"sentry/sentry": "^4.19.1",
		"sentry/sentry-laravel": "^4.20.1",
		"socialiteproviders/twitter": "^4.1.2",
		"spatie/laravel-newsletter": "^5.3.1",
		"spatie/laravel-sitemap": "^7.3.8",
		"staudenmeir/belongs-to-through": "^2.17",
		"symfony/http-client": "^7.4.5",
		"symfony/mailgun-mailer": "^7.4"
	},
	"require-dev": {
		"barryvdh/laravel-debugbar": "^3.16.5",
		"barryvdh/laravel-ide-helper": "^3.6.1",
		"brianium/paratest": "^7.8.5",
		"fakerphp/faker": "^1.24.1",
		"filp/whoops": "^2.18.4",
		"laravel/pint": "^1.27",
		"mockery/mockery": "^1.6.12",
		"phpunit/phpunit": "^11.5.50",
		"rector/rector": "^2.3.5",
		"symfony/thanks": "^1.4.1"
	},
	"autoload": {
		"psr-4": {
			"App\\": "app/",
			"Database\\Factories\\": "database/factories/",
			"Database\\Seeders\\": "database/seeders/"
		},
		"files": [
			"app/Utils/UrlHelpers.php"
		]
	},
	"autoload-dev": {
		"psr-4": {
			"Tests\\": "tests/",
			"Database\\Helpers\\": "database/helpers/"
		}
	},
	"extra": {
		"laravel": {
			"dont-discover": []
		}
	},
	"scripts": {
		"post-root-package-install": [
			"@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
		],
		"post-create-project-cmd": [
			"@php artisan key:generate"
		],
		"post-autoload-dump": [
			"Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
			"@php artisan package:discover"
		],
		"lint": [
			"npm run lint",
			"vendor/bin/pint --parallel --test"
		],
		"format": [
			"npm run format",
			"vendor/bin/pint --parallel"
		]
	},
	"config": {
		"preferred-install": "dist",
		"sort-packages": true,
		"optimize-autoloader": true,
		"platform-check": false,
		"allow-plugins": {
			"symfony/thanks": true,
			"php-http/discovery": true
		},
		"platform": {
			"php": "8.3.29"
		}
	}
}
